@@ -0,0 +1,9 @@
+def first_token(text):
+    """Return the first whitespace-delimited token of text, uppercased."""
+    tokens = text.split()
+    head = tokens[0]
+    return head.upper()
+
+
+def initials(names):
+    return [first_token(n)[0] for n in names]
