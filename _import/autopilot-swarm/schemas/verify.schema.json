{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://autopilot-swarm/schemas/verify.schema.json",
  "title": "VerifierOutput",
  "description": "Verifier evidence block for autopilot-swarm score files",
  "type": "object",
  "required": ["passed", "evidence", "reproductions", "downgraded_to", "notes"],
  "additionalProperties": false,
  "properties": {
    "passed": {
      "type": "boolean"
    },
    "evidence": {
      "type": "object",
      "required": ["cmd_output", "files_checked", "diff_sha"],
      "additionalProperties": false,
      "properties": {
        "cmd_output": {
          "type": "string"
        },
        "files_checked": {
          "type": "array",
          "items": { "type": "string" },
          "minItems": 0
        },
        "diff_sha": {
          "type": "string",
          "pattern": "^[a-f0-9]{7,40}$"
        }
      }
    },
    "reproductions": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["scenario", "cmd", "observed"],
        "additionalProperties": false,
        "properties": {
          "scenario": { "type": "string" },
          "cmd": { "type": "string" },
          "observed": { "type": "string" }
        }
      }
    },
    "downgraded_to": {
      "type": ["null", "string"],
      "enum": [null, "request-changes", "reject"]
    },
    "notes": {
      "type": "string"
    }
  }
}
