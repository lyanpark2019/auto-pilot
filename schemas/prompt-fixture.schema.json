{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://auto-pilot/prompt-fixture/v1",
  "type": "object",
  "required": ["prompt"],
  "properties": {
    "_doc": {"type": "string"},
    "prompt": {"type": "string", "minLength": 1},
    "call": {"enum": ["load", "render"]},
    "vars": {"type": "object"},
    "expects_substring": {"type": "array", "items": {"type": "string"}},
    "expects_not": {"type": "array", "items": {"type": "string"}},
    "adversarial": {"type": "boolean"}
  },
  "additionalProperties": false
}
