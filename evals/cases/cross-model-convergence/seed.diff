+def percentile(values, p):
+    """Return the p-th percentile (0.0..1.0) of a non-empty numeric list.
+
+    p=1.0 must return the maximum.
+    """
+    s = sorted(values)
+    if not s:
+        raise ValueError("percentile() of empty sequence")
+    k = int(len(s) * p)
+    return s[k]
+
+
+MEDIAN = lambda xs: percentile(xs, 0.5)
