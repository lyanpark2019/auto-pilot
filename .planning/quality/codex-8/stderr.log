.github/workflows/ci.yml
name: ci

on:
  push:
    branches: [main]
  pull_request:
    branches: [main]

concurrency:
  group: ${{ github.workflow }}-${{ github.ref }}
  # Never cancel main-branch runs (commit history would show false-negative
  # red X for superseded but otherwise-passing runs). Cancel PR/feature
  # branch runs freely to avoid burning minutes on stale pushes.
  cancel-in-progress: ${{ github.ref != 'refs/heads/main' }}

jobs:
  python:
    name: python gates (ruff + mypy + pytest + bench + prompt-regression)
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - uses: actions/checkout@v5

      - name: setup python
        uses: actions/setup-python@v6
        with:
          python-version: "3.13"
          cache: pip
          cache-dependency-path: requirements-dev.txt

      - name: install deps
        run: |
          python -m pip install --upgrade pip
          python -m pip install -r requirements-dev.txt

      - name: ruff
        run: python -m ruff check scripts/ tests/ hooks/ vault/

      - name: doc reference integrity (file:line citations in docs)
        run: python3 scripts/docs/check_doc_reference_integrity.py

      - name: mypy --strict
        run: python -m mypy  # no args -> mypy.ini files = scripts/ + hooks/ (CI/local scope parity)

      - name: pytest (suite + prompt regression + coverage gate ≥75%)
        # Coverage gate ACTIVE (2026-06-07): pytest-cov in requirements-dev.txt;
        # measured scripts-wide coverage 81.33% at activation. Devs keep running
        # plain `pytest` locally — the gate is CI-only.
        run: python -m pytest tests/ -q --cov=scripts --cov-fail-under=75

      - name: pytest vault export layer
        run: cd vault && python -m pytest tests/ -q

      - name: pytest-benchmark (perf budget + baseline gate)
        run: python -m pytest tests/test_perf.py --benchmark-only -v

  bash:
    name: bash gates (shellcheck)
    runs-on: ubuntu-latest
    timeout-minutes: 2
    steps:
      - uses: actions/checkout@v5

      # Pin to the dev version — the runner's preinstalled shellcheck drifts
      # and would flag style/warning findings 0.11.0 doesn't (see PR #12).
      - name: install shellcheck 0.11.0 (pinned)
        run: |
          curl -fsSL https://github.com/koalaman/shellcheck/releases/download/v0.11.0/shellcheck-v0.11.0.linux.x86_64.tar.xz | tar -xJ
          sudo install -m755 shellcheck-v0.11.0/shellcheck /usr/local/bin/shellcheck
          shellcheck --version | grep version

      - name: shellcheck (hooks + bundled skill + helper scripts)
        run: |
          shellcheck hooks/*.sh
          git ls-files '*.sh' | grep -vE '^hooks/' | xargs -r shellcheck -S warning

      - name: hook self-tests (script-style)
        run: |
          python3 hooks/test_guard_destructive.py
          python3 hooks/test_codex_conductor_guard.py
          python3 hooks/test_notebooklm_delete_gate.py

      - name: module size (≤500 lines, exceptions in module_size_budget.txt)
        run: bash scripts/quality/check-module-size.sh

  bats:
    name: bats gates (adversarial-review-loop + setup-harness)
    runs-on: ubuntu-latest
    timeout-minutes: 3
    steps:
      - uses: actions/checkout@v5

      - name: install bats + jq
        run: sudo apt-get update && sudo apt-get install -y bats jq

      # Pin shellcheck to the dev version. The runner's preinstalled shellcheck
      # drifts from local, so the in-test `shellcheck -S style` gate is otherwise
      # non-reproducible (passes on dev 0.11.0, fails on the runner's older build).
      - name: install shellcheck 0.11.0 (pinned)
        run: |
          curl -fsSL https://github.com/koalaman/shellcheck/releases/download/v0.11.0/shellcheck-v0.11.0.linux.x86_64.tar.xz | tar -xJ
          sudo install -m755 shellcheck-v0.11.0/shellcheck /usr/local/bin/shellcheck
          shellcheck --version | grep version

      - name: bats (ARL orchestration + helpers)
        working-directory: skills/adversarial-review-loop
        run: bats tests/

      - name: bats (setup-harness hooks + CLI)
        working-directory: skills/setup-harness
        run: bats tests/

  manifest:
    name: plugin manifest sanity
    runs-on: ubuntu-latest
    timeout-minutes: 1
    steps:
      - uses: actions/checkout@v5

      - name: validate plugin.json + hooks.json
        run: |
          python -c "import json; json.load(open('.claude-plugin/plugin.json'))"
          python -c "import json; json.load(open('.claude-plugin/marketplace.json'))"
          python -c "import json; json.load(open('hooks/hooks.json'))"

      - name: validate prompt fixture JSON
        run: |
          for f in prompts/fixtures/*.json; do
            python -c "import json,sys; json.load(open('$f'))" || exit 1
          done

  pip-audit:
    name: dep audit (pip-audit)
    runs-on: ubuntu-latest
    timeout-minutes: 5
    steps:
      - uses: actions/checkout@v5

      - name: setup python
        uses: actions/setup-python@v6
        with:
          python-version: "3.13"
          cache: pip
          cache-dependency-path: requirements-dev.txt

      - name: install deps + pip-audit
        run: |
          python -m pip install --upgrade pip
          python -m pip install -r requirements-dev.txt
          python -m pip install pip-audit

      # Audit the installed test toolchain (requirements-dev.txt) against known CVEs.
      # The repo has no application deps beyond stdlib — auditing the dev toolchain
      # is the honest scope; fabricating a separate locked requirements file would
      # create an unmaintained artifact. pip-audit fetches from PyPI's advisory DB.
      - name: pip-audit (dev toolchain CVE scan)
        run: python -m pip_audit --requirement requirements-dev.txt --output json --output-file pip-audit-report.json || python -m pip_audit --requirement requirements-dev.txt

  secret-scan:
    name: secret scan (gitleaks)
    runs-on: ubuntu-latest
    timeout-minutes: 3
    steps:
      - uses: actions/checkout@v5
        with:
          fetch-depth: 0

      # Pinned to commit SHA for supply-chain integrity (v3.0.0 = e0c47f4f8be36e29cdc102c57e68cb5cbf0e8d1e).
      # .gitleaks.toml suppresses two known test-fixture false positives:
      #   - fake github-pat in skills/setup-harness/tests/harness-hooks.bats (line 82)
      #   - idempotency_token hex in tests/fixtures/contracts/sample_contract.json
      - name: gitleaks secret scan
        uses: gitleaks/gitleaks-action@e0c47f4f8be36e29cdc102c57e68cb5cbf0e8d1e
        env:
          GITHUB_TOKEN: ${{ secrets.GITHUB_TOKEN }}
          GITLEAKS_LICENSE: ${{ secrets.GITLEAKS_LICENSE }}

